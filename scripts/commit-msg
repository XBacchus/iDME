#!/usr/bin/env bash
set -euo pipefail

msg_file="$1"
first_line="$(head -n 1 "$msg_file" | tr -d '\r')"
types='feat|fix|docs|style|refactor|test|chore|perf|ci|build|revert'
pattern="^(${types})\\([a-zA-Z0-9._/-]+\\): .+"

if ! echo "$first_line" | grep -Eq "$pattern"; then
  echo "ERROR: Invalid commit message format."
  echo "Required: <type>(<scope>): <subject>"
  echo "Example: feat(api): add xdm query endpoint"
  exit 1
fi

echo "OK: commit-msg check passed."