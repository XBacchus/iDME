{
  "openapi": "3.0.3",
  "info": {
    "title": "iDME MiniApp API",
    "version": "0.1.0"
  },
  "paths": {
    "/api/parts": {
      "post": {
        "summary": "创建物料",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      },
      "get": {
        "summary": "查询物料（支持搜索）",
        "parameters": [
          {
            "name": "keyword",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/parts/{id}": {
      "delete": {
        "summary": "删除物料",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/parts/categories": {
      "get": {
        "summary": "获取分类树",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/parts/{id}/bom": {
      "post": {
        "summary": "添加 BOM 关系",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/equipments": {
      "post": {
        "summary": "创建设备",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/working-plans": {
      "post": {
        "summary": "创建工艺路线",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/working-plans/{id}": {
      "get": {
        "summary": "获取工艺路线详情",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/working-plans/{id}/procedures": {
      "post": {
        "summary": "关联工序",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  }
}
